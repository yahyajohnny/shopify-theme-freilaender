{% comment %}
  Cross-Sell Collections im Warenkorb-Drawer.
  context: 'drawer'
{% endcomment %}

{%- liquid
  assign cross_sell_handles = 'bio-geflugel-pakete,bio-putenfleisch,bio-hahnchenfleisch,bio-wurstprodukte' | split: ','
  assign cross_sell_count = 0

  for handle in cross_sell_handles
    assign cross_sell_collection = collections[handle]
    if cross_sell_collection != blank
      assign cross_sell_count = cross_sell_count | plus: 1
    endif
  endfor
-%}

{%- if cross_sell_count > 0 -%}
  <details class="freilaender-cart-cross-sell freilaender-cart-cross-sell--drawer freilaender-cart-cross-sell--collapsible">
    <summary class="freilaender-cart-cross-sell__title">
      <span>Das könnte dir auch gefallen</span>
      <span class="freilaender-cart-cross-sell__icon">
        {{- 'icon-caret.svg' | inline_asset_content -}}
      </span>
    </summary>

    <ul class="freilaender-cart-cross-sell__grid" role="list">
      {%- for handle in cross_sell_handles -%}
        {%- assign cross_sell_collection = collections[handle] -%}
        {%- if cross_sell_collection != blank -%}
          <li class="freilaender-cart-cross-sell__grid-item">
            <a href="{{ cross_sell_collection.url }}" class="freilaender-cart-cross-sell__link">
              {%- if cross_sell_collection.featured_image -%}
                <img
                  class="freilaender-cart-cross-sell__image"
                  src="{{ cross_sell_collection.featured_image | image_url: width: 160 }}"
                  alt="{{ cross_sell_collection.featured_image.alt | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              {%- else -%}
                <span class="freilaender-cart-cross-sell__image freilaender-cart-cross-sell__image--placeholder"></span>
              {%- endif -%}
              <span class="freilaender-cart-cross-sell__name">{{ cross_sell_collection.title | escape }}</span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </details>
{%- endif -%}
