{% comment %}
  Cross-Sell Collections im Warenkorb (gleiche Auswahl wie cart.json).
  context: 'drawer'
{% endcomment %}

{%- liquid
  assign cross_sell_handles = 'bio-geflugel-pakete,bio-putenfleisch,bio-hahnchenfleisch,bio-wurstprodukte' | split: ','
  assign cross_sell_count = 0

  for handle in cross_sell_handles
    assign cross_sell_collection = collections[handle]
    if cross_sell_collection != blank
      assign cross_sell_count = cross_sell_count | plus: 1
    endif
  endfor
-%}

{%- if cross_sell_count > 0 -%}
  <div class="freilaender-cart-cross-sell{% if context == 'drawer' %} freilaender-cart-cross-sell--drawer{% endif %}">
    <h3 class="freilaender-cart-cross-sell__title">Das könnte dir auch gefallen</h3>

    <slider-component class="freilaender-cart-cross-sell__slider slider-mobile-gutter">
      <ul
        class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid slider slider--tablet grid--peek collection-list--{{ cross_sell_count }}-items"
        id="Freilaender-CartCrossSell"
        role="list"
      >
        {%- assign item_index = 0 -%}
        {%- for handle in cross_sell_handles -%}
          {%- assign cross_sell_collection = collections[handle] -%}
          {%- if cross_sell_collection != blank -%}
            {%- assign item_index = item_index | plus: 1 -%}
            {%- assign placeholder_image_index = item_index | minus: 1 | modulo: 4 | plus: 1 -%}
            {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
            <li
              id="Freilaender-CartCrossSell-{{ item_index }}"
              class="collection-list__item grid__item slider__slide{% if cross_sell_collection.featured_image == nil %} collection-list__item--no-media{% endif %}"
            >
              {% render 'card-collection',
                card_collection: cross_sell_collection,
                media_aspect_ratio: 'square',
                columns: 2,
                placeholder_image: placeholder_image
              %}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if cross_sell_count > 1 -%}
        <div class="slider-buttons no-js-hidden">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ cross_sell_count }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>
  </div>
{%- endif -%}
