{% comment %}
  Custom Warenkorb-Footer: Wunschlieferdatum + Hextom Shipping Bar.
  part: 'delivery' | 'shipping-bar' | blank (beides)
{% endcomment %}

{% unless part == 'shipping-bar' %}
  {% assign has_festtags = false %}

  {% for item in cart.items %}
    {% if item.product.tags contains 'Festtagsgeflügel' or item.product.tags contains 'Freilandpute' %}
      {% assign has_festtags = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% unless has_festtags %}
    {%- liquid
      assign show_bird_widget = false
      if context == 'drawer' and template.name != 'cart'
        assign show_bird_widget = true
      elsif context != 'drawer' and template.name == 'cart'
        assign show_bird_widget = true
      endif

      if context == 'drawer'
        assign delivery_accordion_id = 'Details-Wunschlieferdatum-Drawer'
      else
        assign delivery_accordion_id = 'Details-Wunschlieferdatum-Cart'
      endif
    -%}

    <div class="delivery_date_picker_container freilaender-delivery-accordion-wrapper{% if context == 'drawer' %} freilaender-delivery-accordion-wrapper--drawer{% endif %}">
      <style>
        .bcdp-methods-container {
          display: none;
        }
      </style>

      <details id="{{ delivery_accordion_id }}" class="freilaender-delivery-accordion{% if context == 'drawer' %} freilaender-cart-option-card{% else %} freilaender-cart-option-card freilaender-cart-option-card--page{% endif %}">
        <summary>
          {% if context == 'drawer' %}
            <span class="summary__title freilaender-cart-delivery-summary">
              <span class="freilaender-cart-delivery-summary__text">
                <span class="freilaender-cart-option-card__label">
                  <span class="freilaender-cart-option-card__title">Wunschlieferdatum (optional)</span>
                  <span class="freilaender-cart-option-card__hint">Versand Di–Fr, späterer Termin möglich</span>
                </span>
              </span>
              <span class="freilaender-cart-delivery-summary__icon">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </span>
          {% else %}
            <span class="summary__title">
              Wunschlieferdatum (optional)
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          {% endif %}
        </summary>

        <div class="freilaender-delivery-accordion__content">
          {% unless context == 'drawer' %}
            <p class="freilaender-cart-footer-extras__text">
              Wir versenden täglich von Dienstag bis Freitag, damit Sie Ihre Ware schnellstmöglich erhalten.
              Sie wünschen ein späteres Lieferdatum? Wählen Sie einen Wunschtermin ... <sup>(optional)</sup>
            </p>
          {% endunless %}

          {% if show_bird_widget %}
            <div
              class="freilaender-bird-mount"
              data-freilaender-bird-mount
              {% if context == 'drawer' %}
                data-watch-ajax="cart-drawer-items"
              {% endif %}
            ></div>
          {% endif %}
        </div>
      </details>
    </div>
  {% endunless %}
{% endunless %}

{% unless part == 'delivery' %}
  {% assign show_placeholder = true %}
  {% for item in cart.items %}
    {% if item.product.handle == 'bio-thanksgiving-pute' or item.product.handle == 'bio-waldland-weihnachtspute-kellybronze' or item.product.handle == 'bio-weihnachtsente' %}
      {% assign show_placeholder = false %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if show_placeholder %}
    <div id="fsb_placeholder" class="freilaender-fsb-placeholder"></div>
  {% endif %}
{% endunless %}

{% if part == blank or part == 'delivery' %}
  <style>
    .freilaender-delivery-accordion {
      border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.2);
    }

    .freilaender-delivery-accordion summary {
      display: flex;
      position: relative;
      line-height: 1;
      padding: 1.5rem 2.8rem 1.5rem 0;
      cursor: pointer;
      list-style: none;
    }

    .freilaender-delivery-accordion summary::-webkit-details-marker {
      display: none;
    }

    .freilaender-delivery-accordion .summary__title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      font-size: 1.4rem;
      font-weight: 600;
    }

    .freilaender-delivery-accordion .summary__title .icon-caret {
      height: 0.6rem;
      transition: transform var(--duration-short) ease;
    }

    .freilaender-delivery-accordion[open] > summary .icon-caret {
      transform: rotate(180deg);
    }

    .freilaender-delivery-accordion[open] {
      padding-bottom: 1.5rem;
    }

    .freilaender-delivery-accordion__content {
      padding-top: 0.25rem;
    }

    .freilaender-cart-footer-extras__text {
      font-size: 14px;
      margin: 0 0 1rem;
      line-height: 1.5;
    }
  </style>
{% endif %}

{% if part == blank or part == 'shipping-bar' %}
  <style>
    .freilaender-fsb-placeholder {
      padding-bottom: 1rem;
      position: relative;
      z-index: 1;
    }
  </style>
{% endif %}
