{% comment %}
  Custom Warenkorb-Footer: Wunschlieferdatum + Hextom Shipping Bar Platzhalter.
  part: 'delivery' | 'shipping-bar' | blank (beides)
{% endcomment %}

{% unless part == 'shipping-bar' %}
  {% assign has_festtags = false %}

  {% for item in cart.items %}
    {% if item.product.tags contains 'Festtagsgeflügel' or item.product.tags contains 'Freilandpute' %}
      {% assign has_festtags = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  <div class="delivery_date_picker_container">
    <style>
      .bcdp-methods-container {
        display: none;
      }
    </style>

    {% unless has_festtags %}
      <h4 class="freilaender-cart-footer-extras__heading">Wunschlieferdatum (optional)</h4>
      <p class="freilaender-cart-footer-extras__text">
        Wir versenden täglich von Dienstag bis Freitag, damit Sie Ihre Ware schnellstmöglich erhalten.
        Sie wünschen ein späteres Lieferdatum? Wählen Sie einen Wunschtermin ... <sup>(optional)</sup>
      </p>
    {% endunless %}

    {%- liquid
      assign show_bird_widget = false
      if context == 'drawer' and template.name != 'cart'
        assign show_bird_widget = true
      elsif context != 'drawer' and template.name == 'cart'
        assign show_bird_widget = true
      endif
    -%}

    {% if show_bird_widget %}
      <div
        id="birdchime-slots-box"
        {% if context == 'drawer' %}
          data-watch-ajax="cart-drawer-items"
        {% endif %}
      ></div>
    {% endif %}
  </div>
{% endunless %}

{% unless part == 'delivery' %}
  {% assign show_placeholder = true %}
  {% for item in cart.items %}
    {% if item.product.handle == 'bio-thanksgiving-pute' or item.product.handle == 'bio-waldland-weihnachtspute-kellybronze' or item.product.handle == 'bio-weihnachtsente' %}
      {% assign show_placeholder = false %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if show_placeholder %}
    <div id="fsb_placeholder" class="freilaender-fsb-placeholder"></div>
  {% endif %}
{% endunless %}

{% if part == blank or part == 'delivery' %}
  <style>
    .freilaender-cart-footer-extras__heading {
      margin: 0 0 0.5rem;
      font-size: 1.4rem;
    }

    .freilaender-cart-footer-extras__text {
      font-size: 14px;
      margin: 0 0 1rem;
    }
  </style>
{% endif %}

{% if part == blank or part == 'shipping-bar' %}
  <style>
    .freilaender-fsb-placeholder {
      padding-bottom: 1rem;
      position: relative;
      z-index: 1;
    }
  </style>
{% endif %}
